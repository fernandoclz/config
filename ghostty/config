# Font Configuration
font-size = 12

# Window Configuration
window-decoration = false
window-padding-x = 12
window-padding-y = 12
window-height = 30
window-width = 90
background-opacity = 0.9
background-blur = 20
background-blur-radius = 32

# Cursor Configuration
cursor-style = block
cursor-style-blink = true

# Scrollback
scrollback-limit = 3023

# Terminal features
mouse-hide-while-typing = true
copy-on-select = true
confirm-close-surface = false

# Disable annoying copied to clipboard
app-notifications = no-clipboard-copy,no-config-reload

# Key bindings for common actions
#keybind = ctrl+c=copy_to_clipboard
#keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
keybind = ctrl+q=close_tab

# Material 3 UI elements
unfocused-split-opacity = 0.7
unfocused-split-fill = #44464f

# Tab configuration
gtk-titlebar = false

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title,no-cursor
keybind = shift+enter=text:\n

# Rando stuff
gtk-single-instance = true

# Ejemplo para añadir decoraciones de ventana tradicionales
window-decoration = true

macos-titlebar-style = tabs

# Hace que la fuente se vea un poco más gruesa y legible
font-family = "JetBrainsMono Nerd Font"
font-size = 12
font-thicken = true

window-padding-x = 10
window-padding-y = 10

# Colores oficiales de Apple Terminal (Dark)
palette = 0=#000000
palette = 1=#990000
palette = 2=#00a600
palette = 3=#999900
palette = 4=#0000b2
palette = 5=#b200b2
palette = 6=#00a6b2
palette = 7=#bfbfbf
palette = 8=#666666
palette = 9=#e50000
palette = 10=#00d900
palette = 11=#e5e500
palette = 12=#0000ff
palette = 13=#e500e5
palette = 14=#00e5e5
palette = 15=#e5e5e5

background = #000000
foreground = #ffffff
cursor-color = #ffffff
